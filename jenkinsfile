pipeline {
    agent any

    stages {

        stage('Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }

            environment {
                npm_config_cache = './.npm'
            }

            steps {
                sh '''
                    ls -la
                    node --version
                    npm --version

                    npm ci

                    npm run build

                    ls -la
                '''
            }
        }

        stage('Test') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }

            environment {
                npm_config_cache = './.npm'
            }

            steps {
                sh '''
                    test -f build/index.html
                    npm test
                '''
            }
        }

        stage('Deploy to Render') {
            agent {
                docker {
                    image 'node:18'
                    reuseNode true
                }
            }

            steps {
                sh '''
                    curl -fsSL https://raw.githubusercontent.com/render-oss/cli/refs/heads/main/bin/install.sh | sh

                    export PATH="$HOME/.local/bin:$PATH"

                    render --version
                '''
            }
        }
    }

    post {

        success {
            echo 'Pipeline completed - app deployed to Render successfully'
        }

        failure {
            echo 'Pipeline failed - deployment to Render did not occur'
        }
    }
}